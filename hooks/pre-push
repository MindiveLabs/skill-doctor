#!/usr/bin/env bash
# pre-push — Fail the push if VERSION wasn't bumped relative to main.
#
# Install (from repo root):
#   ln -sf "$(pwd)/hooks/pre-push" .git/hooks/pre-push
#
# This ensures every change pushed to a feature branch carries a version bump,
# so users of the installed skill receive update notifications automatically.

# Resolve main's VERSION (prefer origin/main, fall back to local main)
MAIN_VERSION=$(git show "origin/main:VERSION" 2>/dev/null | tr -d '[:space:]')
if [[ -z "$MAIN_VERSION" ]]; then
  MAIN_VERSION=$(git show "main:VERSION" 2>/dev/null | tr -d '[:space:]')
fi

# No main branch yet (initial repo setup) — nothing to compare against
[[ -z "$MAIN_VERSION" ]] && exit 0

CURRENT_VERSION=$(cat VERSION 2>/dev/null | tr -d '[:space:]')
if [[ -z "$CURRENT_VERSION" ]]; then
  echo "pre-push: VERSION file not found" >&2
  exit 1
fi

while read -r local_ref local_sha remote_ref _remote_sha; do
  # Skip deletions (git push --delete)
  [[ "$local_sha" == "0000000000000000000000000000000000000000" ]] && continue
  # Skip direct pushes to main (GitHub merges; local hotfixes)
  [[ "$remote_ref" == "refs/heads/main" ]] && continue

  if [[ "$CURRENT_VERSION" == "$MAIN_VERSION" ]]; then
    echo "" >&2
    echo "pre-push blocked: VERSION not bumped (still $CURRENT_VERSION, same as main)" >&2
    echo "" >&2
    echo "Bump VERSION before pushing, e.g.:" >&2
    echo "  echo '0.2.0' > VERSION" >&2
    echo "  git add VERSION && git commit --amend --no-edit" >&2
    echo "" >&2
    exit 1
  fi
done

exit 0
