#!/usr/bin/env bash
# setup — Install skill-doctor to ~/.claude/skills/skill-doctor/
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# SKILL_DOCTOR_INSTALL_DIR can override the install path (used for testing)
INSTALL_DIR="${SKILL_DOCTOR_INSTALL_DIR:-${HOME}/.claude/skills/skill-doctor}"

echo "Installing skill-doctor..."

# Create install directory
mkdir -p "$INSTALL_DIR/bin"

# Copy files
cp "$SCRIPT_DIR/SKILL.md"  "$INSTALL_DIR/SKILL.md"
cp "$SCRIPT_DIR/VERSION"   "$INSTALL_DIR/VERSION"
cp "$SCRIPT_DIR/bin/"*     "$INSTALL_DIR/bin/"

# Make binaries executable
chmod +x "$INSTALL_DIR/bin/"*

echo "skill-doctor installed at $INSTALL_DIR"
echo ""
echo "Run /skill-doctor in a Claude Code session to scan for conflicts."
